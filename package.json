{
  "name": "claudecode-usage",
  "displayName": "Claude Code Usage Monitor",
  "description": "Shows your Claude Pro/Max quota usage in the status bar — 5-hour and 7-day rolling windows as live progress bars with reset countdown. Requires Claude Code CLI to be installed and authenticated.",
  "version": "1.0.0",
  "publisher": "AndJae",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndyJae/claude-code-usage"
  },
  "engines": { "vscode": "^1.85.0" },
  "keywords": ["claude", "claude-code", "anthropic", "usage", "quota", "monitor", "status-bar", "vscode-extension"],
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeUsage.refresh",
        "title": "Claude Usage: Refresh Now"
      },
      {
        "command": "claudeUsage.toggleMode",
        "title": "Claude Usage: Toggle View (5h / 7d / Both)"
      }
    ],
    "configuration": {
      "title": "Claude Usage Monitor",
      "properties": {
        "claudeUsage.refreshIntervalSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "description": "How often to refresh usage data (seconds)"
        },
        "claudeUsage.defaultMode": {
          "type": "string",
          "enum": ["5h", "7d", "both"],
          "default": "both",
          "description": "Which limit to show in status bar: 5h window, 7d window, or both"
        },
        "claudeUsage.credentialsPath": {
          "type": "string",
          "default": "",
          "description": "Override path to .credentials.json (leave empty for auto-detect)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
